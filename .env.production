# wa production environment (committed defaults)
#
# Loaded by `make prod` and by `wa --env production ...`. Put deployment-
# specific secrets and overrides in `.env.production.local`.

WA_ENV=production

# Ports the production stack listens on.
# Same-machine CLI defaults use WA_PROD_RESULTS_PORT for `wa results ...` and
# WA_PROD_SEQMETA_PORT for `wa mlwh info`.
WA_PROD_FRONTEND_PORT=3000
WA_PROD_RESULTS_PORT=8090
WA_PROD_SEQMETA_PORT=8091

# Results API bind host used by `make prod` and by
# `wa --env production results serve` when `--url` is not supplied. Leave blank
# for loopback, or set to 0.0.0.0 in .env.production.local to accept remote
# connections. Normal remote CLI users should export WA_RESULTS_SERVER_URL with
# the full public API URL instead.
WA_PROD_RESULTS_HOST=

# MLWH API bind host used by `make prod` and by
# `wa --env production mlwh serve` when `--url` is not supplied. Leave blank for
# loopback, or set to 0.0.0.0 in .env.production.local to accept remote
# connections. Normal remote CLI users should export WA_MLWH_SERVER_URL with
# the full public MLWH API URL instead; this server is plain HTTP unless
# WA_MLWH_SERVER_CERT, WA_MLWH_SERVER_KEY, and WA_MLWH_SERVER_TOKEN are set.
WA_PROD_SEQMETA_HOST=

# Production database. For MySQL, either put the full DSN here or prefer a
# passwordless DSN such as `user@tcp(db-host:3306)/wa_results` and set
# WA_RESULTS_DB_PASSWORD below so the password never appears on a command line.
# For SQLite, supply an absolute path outside the repo (for example
# /var/lib/wa/results.db).
WA_RESULTS_DB_PATH=

# Optional MySQL password used with a passwordless WA_RESULTS_DB_PATH.
WA_RESULTS_DB_PASSWORD=

# Frontend study-list cache TTL in seconds.
WA_STUDIES_CACHE_TTL_SECONDS=300

# MLWH source and cache settings for `wa mlwh sync` / `wa mlwh serve` in
# production.
WA_MLWH_DSN=
WA_MLWH_PASSWORD=
WA_MLWH_CACHE_PATH=
WA_MLWH_CACHE_PASSWORD=
