WA_TEST_FRONTEND_PORT=3000
WA_TEST_RESULTS_PORT=8090
WA_TEST_SEQMETA_PORT=8091
WA_RESULTS_BACKEND_URL=http://localhost:8090
WA_SEQMETA_BACKEND_URL=
WA_STUDIES_CACHE_TTL_SECONDS=300
WA_RESULTS_DB_PATH=./dev.db
SAGA_API_TOKEN=

# Extra hostnames the Next.js dev server should accept cross-origin requests
# from. `run-dev.sh` already injects `localhost`, `127.0.0.1`, and the
# machine's `hostname -f`/`hostname -s`. Set this (comma separated) if you
# access `make run` from a host that isn't covered by those defaults;
# otherwise leave empty. Only applies when NODE_ENV != production.
WA_DEV_ALLOWED_ORIGINS=