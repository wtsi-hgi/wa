WA_RESULTS_BACKEND_URL=https://localhost:8090
WA_RESULTS_BACKEND_CA_CERT=
WA_MLWH_BACKEND_URL=
WA_STUDIES_CACHE_TTL_SECONDS=300

# Extra hostnames the Next.js dev server should accept cross-origin requests
# from (comma separated). Merged with the defaults baked into next.config.ts:
# `localhost` and `127.0.0.1`. Only honoured when NODE_ENV != production.
WA_DEV_ALLOWED_ORIGINS=
