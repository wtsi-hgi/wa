# wa production environment template
#
# Copy to `.env.prod` (gitignored) and edit. Loaded ONLY by `make prod` via
# scripts/wa-env.sh. The wrapper refuses to start if any of the following are
# true:
#   - .env.prod is missing
#   - WA_ENV is not set to "production" inside this file
#   - any WA_TEST_*_PORT or WA_DEV_*_PORT variable is inherited from the shell
# The runner script also refuses --fixtures in this mode.

WA_ENV=production

# Ports the production stack listens on.
WA_PROD_FRONTEND_PORT=3000
WA_PROD_RESULTS_PORT=8090
WA_PROD_SEQMETA_PORT=8091

# Production database. For MySQL, supply a DSN containing `@tcp(` or `@unix(`.
# Example: WA_RESULTS_DB_PATH='user:pass@tcp(db-host:3306)/wa_results'
# For SQLite, supply an absolute path outside the repo (e.g. /var/lib/wa/results.db).
WA_RESULTS_DB_PATH=

# Frontend study-list cache TTL in seconds.
WA_STUDIES_CACHE_TTL_SECONDS=300

# SAGA API token. Required if the seqmeta server is part of the deployment.
SAGA_API_TOKEN=
