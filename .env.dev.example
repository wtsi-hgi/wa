# wa dev environment template
#
# Copy to `.env.dev` (gitignored) and edit. Loaded by `make dev` via
# scripts/wa-env.sh. This scenario brings up a real-feel dev stack with a
# persistent SQLite database; `make dev` does not delete the DB on shutdown.
#
# Use `make dev FIXTURES=1` (or `make dev-fixtures`) to additionally seed the
# results fixtures from .docs/results-web/fixtures/seed.json into the dev DB.

WA_ENV=development

# Ports the dev stack listens on. Pick anything not in use by `make test`.
WA_DEV_FRONTEND_PORT=3671
WA_DEV_RESULTS_PORT=3672
WA_DEV_SEQMETA_PORT=3673

# Persistent dev SQLite database. Created on first run if missing. Keep this
# inside the repo (e.g. .tmp/dev.db) so it cannot collide with prod paths.
WA_RESULTS_DB_PATH=.tmp/dev.db

# Frontend study-list cache TTL in seconds.
WA_STUDIES_CACHE_TTL_SECONDS=300

# SAGA API token for seqmeta-backed dev. Required for the seqmeta server to
# start; without it the dev stack runs without seqmeta enrichment.
SAGA_API_TOKEN=

# Extra hostnames the Next.js dev server should accept cross-origin requests
# from (comma separated). Defaults already cover localhost, 127.0.0.1, and
# the current `hostname -f`/`hostname -s`. Only honoured when WA_ENV != production.
WA_DEV_ALLOWED_ORIGINS=
