# wa test environment (committed)
#
# Loaded by `make test` via scripts/wa-env.sh. This scenario is hermetic:
#   - run-dev.sh runs in --mode test and always uses an ephemeral mktemp DB
#     under .tmp/, deleted on shutdown. WA_RESULTS_DB_PATH is intentionally
#     NOT set here.
#   - Playwright defaults to allocating throwaway TCP ports on 127.0.0.1; the
#     WA_TEST_*_PORT overrides below pin them when CI or local debugging
#     requires reproducible ports. Leave them blank for full isolation.
#   - SAGA_API_TOKEN belongs in .env.dev only; tests may optionally reuse that
#     gitignored token for live SAGA-backed integration coverage, but this
#     committed test env file must never store real credentials.
#
# Never put WA_RESULTS_DB_PATH, real SAGA tokens, or production hostnames in
# this file. The wa-env.sh wrapper rejects WA_ENV=production for `make test`.

WA_ENV=test

# Optional pinned ports for Playwright. When unset, Playwright allocates fresh
# ephemeral ports per run. Override only if a specific port range is required.
WA_TEST_FRONTEND_PORT=
WA_TEST_RESULTS_PORT=
WA_TEST_SEQMETA_PORT=
