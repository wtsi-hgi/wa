# wa test environment (committed)
#
# Loaded by `make test`. This scenario is hermetic:
#   - run-dev.sh runs in --mode test and always uses an ephemeral mktemp DB
#     under .tmp/, deleted on shutdown. WA_RESULTS_DB_PATH is intentionally
#     NOT set here.
#   - Playwright defaults to allocating throwaway TCP ports on 127.0.0.1; the
#     WA_TEST_*_PORT overrides below pin them when CI or local debugging
#     requires reproducible ports. Leave them blank for full isolation.
#
# Never put WA_RESULTS_DB_PATH, real MLWH credentials, or production hostnames in
# this file. Test-mode results CLI defaults stay on loopback; there is no
# committed WA_TEST_RESULTS_HOST override. The test runner rejects
# WA_ENV=production for `make test`.

WA_ENV=test

# Test-mode results auth uses server-owner-token login for fixture seeding and
# test-only LDAP placeholders to satisfy secure server validation. The fake
# LDAP host must not be used by development or production mode.
WA_RESULTS_SERVER_CERT=.tmp/wa-dev-cert.pem
WA_RESULTS_SERVER_KEY=.tmp/wa-dev-key.pem
WA_RESULTS_LDAP_SERVER=wa-test-ldap.invalid
WA_RESULTS_LDAP_DN=uid=%s,ou=people,dc=example,dc=org

# Optional pinned ports for Playwright. When unset, Playwright allocates fresh
# ephemeral ports per run. Override only if a specific port range is required.
WA_TEST_FRONTEND_PORT=
WA_TEST_RESULTS_PORT=
WA_TEST_SEQMETA_PORT=
